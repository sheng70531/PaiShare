{
  "name": "paishare",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "export:web": "expo export -p web",
    "predeploy": "cross-env GITHUB_PAGES=true expo export -p web",
    "deploy": "node scripts/prepare-gh-pages.js && gh-pages --nojekyll -d dist",
    "test:settlement": "tsx src/lib/settlement.selfcheck.ts",
    "test:lib": "tsx src/lib/settlement.selfcheck.ts && tsx src/lib/remove-person.selfcheck.ts",
    "activate": "powershell -NoExit -File .venv/Activate.ps1"
  },
  "dependencies": {
    "@expo-google-fonts/fraunces": "^0.4.1",
    "@expo-google-fonts/outfit": "^0.4.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~57.0.6",
    "expo-constants": "~57.0.5",
    "expo-font": "~57.0.1",
    "expo-linking": "~57.0.3",
    "expo-router": "~57.0.6",
    "expo-status-bar": "~57.0.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.10.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "babel-preset-expo": "^57.0.3",
    "cross-env": "^7.0.3",
    "gh-pages": "^6.3.0",
    "tsx": "^4.23.1",
    "typescript": "~6.0.3"
  },
  "private": true
}
